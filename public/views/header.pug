header#header.header.text-center
    div#bg-header
    div.force-overflow
        h2.blog-name.pt-lg-4.mb-0
            a.no-text-decoration.text-light(href="/") Rodrigo Mady
        
        nav.navbar.navbar-expand-lg.navbar-dark
            
            button#navbar-toggler.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navigation" aria-controls="navigation" aria-expanded="false" aria-label="Toggle navigation")
                span.navbar-toggler-icon
            
            div#navigation.collapse.navbar-collapse.flex-column
                div.profile-section.pt-3.pt-lg-0
                    a(href="/")
                        img.profile-image.mb-3.mx-auto(src="/images/profile.jpg" alt="image" width="128px")
                    div.bio #{bio}
                    div.bio.mb-3 #{welcome}
                        ul.social-list.list-inline.py-2.mx-auto
                            li.list-inline-item
                                a(href="https://www.linkedin.com/in/rodrigo-mady/" target="_blank")
                                    i.fa.fa-linkedin-square.fa-2x.text-light                                    
                            li.list-inline-item
                                a(href="https://www.facebook.com/rodrigo.mady" target="_blank")                                    
                                    i.fa.fa-facebook-square.fa-2x.text-light     
                            li.list-inline-item
                                a(href="https://github.com/rmady" target="_blank")                                    
                                    i.fa.fa-github-square.fa-2x.text-light   
                            li.list-inline-item
                                a(href="mailto:rodrigo.mady@gmail.com" target="_blank")                                    
                                    i.fa.fa-google.fa-2x.text-light
                    hr.mb-4
                div.dark-mode-toggle.text-center.w-100
                    ul.navbar-nav.flex-column.text-center
                        li.nav-item
                            i.fa.fa-language 
                            span.ml-2 #{sitelanguage}
                        span.float-left
                            a.d-inline-block.text-light.no-text-decoration(href="?lang=en") en
                            a.d-inline-block.text-light.no-text-decoration.ml-1(href="?lang=pt") pt
                    hr.mb-4            
                ul.navbar-nav.flex-column.text-start.w-100
                    li.nav-item(class = active === "home" ? "active" : "")
                        a.nav-link(href="/")
                            i.fa.fa-user.text-light
                            span.ml-2 #{aboutme} 
                    li.nav-item(class = active === "skills" ? "active" : "")
                        a.nav-link(href="/skills")
                            i.fa.fa-file-code-o.text-light
                            span.ml-2 #{skills}
                    li.nav-item(class = active === "portfolio" ? "active" : "")
                        a.nav-link(href="/portfolio")
                            i.fa.fa-graduation-cap.text-light
                            span.ml-2 #{portfolio}
                    li.nav-item(class = active === "talks" ? "active" : "")
                        a.nav-link(href="/talks")
                            i.fa.fa-volume-up.text-light
                            span.ml-2 #{talks}  
                    li.nav-item(class = active === "trema" ? "active" : "")
                        a.nav-link(href="/trema") 
                            i.fa.fa-code.text-light
                            span.ml-2 #{trema}
                div.purple-mode-toggle.text-center.w-100
                    hr.mb-4
                    ul.navbar-nav.flex-column
                        li.nav-item.d-flex.align-items-center.pl-4
                            i.fa.fa-adjust 
                            span.ml-2 #{purplemode}
                            input#purplemode.toggle(type="checkbox" onclick="purpleMode()")
                            label.toggle-btn.mx-auto.mb-0(for="purplemode")