
section.trema-section.section.py-5.theme-bg-light-gradient.p-3.p-lg-5
    div.container
        h3.section-title.font-weight-bold.mb-3 #{trema}
        div.section-intro.mx-auto.mb-5 #{tremadesc}

        div.slideshow
            div.slideshow-inner
                div.slides
                    div.slide.is-active
                        div.image-container 
                            img.image(src="/images/slideshow/login.gif" alt="")                
                    div.slide
                        div.slide-content
                            div.caption
                                div.title Frontpage
                        div.image-container
                            img.image(src="/images/slideshow/frontpage.gif" alt="")
                    div.slide
                        div.slide-content
                            div.caption
                                div.title Incourse           
                        div.image-container
                            img.image(src="/images/slideshow/incourse.png" alt="")
                div.pagination
                    div.item.is-active 
                        span.icon 1                
                    div.item
                        span.icon 2                
                    div.item
                        span.icon 3                
                div.arrows
                    div.arrow.prev
                        span.svg.svg-arrow-left
                            svg(version="1.1" id="svg4-Layer_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" width="14px" height="26px" viewBox="0 0 14 26" enable-background="new 0 0 14 26" xml:space="preserve") 
                                path(d="M13,26c-0.256,0-0.512-0.098-0.707-0.293l-12-12c-0.391-0.391-0.391-1.023,0-1.414l12-12c0.391-0.391,1.023-0.391,1.414,0s0.391,1.023,0,1.414L2.414,13l11.293,11.293c0.391,0.391,0.391,1.023,0,1.414C13.512,25.902,13.256,26,13,26z")
                            span.alt.sr-only
                    div.arrow.next
                        span.svg.svg-arrow-right
                            svg(version="1.1" id="svg5-Layer_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" width="14px" height="26px" viewBox="0 0 14 26" enable-background="new 0 0 14 26" xml:space="preserve")
                                path(d="M1,0c0.256,0,0.512,0.098,0.707,0.293l12,12c0.391,0.391,0.391,1.023,0,1.414l-12,12c-0.391,0.391-1.023,0.391-1.414,0s-0.391-1.023,0-1.414L11.586,13L0.293,1.707c-0.391-0.391-0.391-1.023,0-1.414C0.488,0.098,0.744,0,1,0z")
                            span.alt.sr-only
                
        div.text-center 
            div.infolabels.justify-content-center.d-flex.align-items-center.my-3 
                    div.timelastreleased.mr-3
                        span.stats-timelastreleased
                    div.usage.mr-3
                        span.stats-sites 
                            i.fa.fa-map-marker(aria-hidden="true") 
                            span.ml-1 #{tremasites}
                    div.downloads.mr-3
                        span.stats-downloads
                            i.fa.fa-download(aria-hidden="true")  
                            span.ml-1 #{tremadownloads}
                    div.favourites.mr-3
                        span.stats-fans(title="Favourited by 82 user(s)")
                            i.fa.fa-heart(aria-hidden="true")  
                            span.ml-1 #{tremalikes}
            div.text-center.mt-2.d-flex.d-sm-block.justify-content-center.align-items-center
                a.btn.btn-outline-primary(href="https://moodle.org/plugins/theme_trema" target="_blank") Download
                    i.fa.fa-download.ml-2
                a.btn.ml-4.btn-outline-primary(href="https://github.com/trema-tech/moodle-theme_trema" target="_blank") #{sourcecode}
                    i.fa.fa-github.ml-2
                a.btn.ml-4.btn-outline-primary(href="https://trema.rmady.com.br" target="_blank") Demo site
                    i.fa.fa-globe.ml-2                    
                a.btn.ml-4.btn-outline-primary(href="https://www.paypal.com/donate/?hosted_button_id=6FBZMX8PFPS3Y&source=qr" target="_blank") #{donate}
                    i.fa.fa-paypal.ml-2
    div.navigation
        ul.nav.nav-pills.justify-content-between
            li.nav-item
                a.nav-link(href="/talks" data-bs-toggle="pill") #{talks}